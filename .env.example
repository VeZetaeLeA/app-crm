# ===========================================
# VEZETAELEA OS - CONFIGURACIÓN DE ENTORNO
# ===========================================

# ===========================================
# VARIABLE OBLIGATORIA: local | demo | production
# ===========================================
ENVIRONMENT=local

# ===========================================
# APLICACIÓN
# ===========================================
APP_NAME="VeZetaeLeA OS"
APP_URL=http://localhost/app-crm
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_CHARSET=UTF-8
APP_LOCALE=es
APP_KEY=generar_clave_32_caracteres

# ===========================================
# BASE DE DATOS
# ===========================================
DB_HOST=localhost
DB_DATABASE=vezetaelea
DB_USERNAME=root
DB_PASSWORD=

# ===========================================
# REDIS (INFRAESTRUCTURA)
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# SEGURIDAD Y JWT
# ===========================================
JWT_SECRET=super-secret-token-change-this
JWT_TTL=3600
REFRESH_TOKEN_TTL=2592000 # 30 días

SESSION_LIFETIME=14400
SESSION_HEARTBEAT=300
SESSION_WARNING=300

# ===========================================
# SECURITY HARDENING
# ===========================================
AUTH_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY=60
AUTH_BRUTE_FORCE_BLOCK=1800
AUTH_ACCOUNT_LOCK=900
AUTH_HASH_ALGO=argon2id
GLOBAL_RATE_LIMIT=100
GLOBAL_RATE_LIMIT_WINDOW=60

# ===========================================
# EMAIL (Configurar para demo/production)
# ===========================================
MAIL_ENABLED=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=contacto@vezetaelea.com
MAIL_FROM_NAME="VeZetaeLeA OS"

# ===========================================
# TIPOGRAFÍA Y ESTÉTICA (UX)
# ===========================================
FONT_HEADING="'Space Grotesk', sans-serif"
FONT_BODY="'Outfit', sans-serif"
TYPO_SCALE_RATIO=1.25

# ===========================================
# PARÁMETROS DE NEGOCIO (SLA & BRANDING)
# ===========================================
COMPANY_NAME="VeZetaeLeA"
COMPANY_SLOGAN="Ingeniería de Datos de Vanguardia"
COMPANY_MAIL="contacto@vezetaelea.com"
COMPANY_PHONE="+54 9 11 7021 5822"
COMPANY_ADDRESS="Corrientes 5712, Villa Crespo, CP 1414, CABA, Argentina"
COMPANY_EST_YEAR="2017"

SLA_RESPONSE_TIME="24h"
CURRENCY_SYMBOL="$"
TAX_RATE=0.21
SHOW_ENTERPRISE_PROFILE=false
COMPANY_YEARS_EXP=10
COMPANY_PROJECTS_DELIVERED=45

# ===========================================
# SOCIAL MEDIA links
# ===========================================
SOCIAL_INSTAGRAM="https://www.instagram.com/vezetaelea/"
SOCIAL_LINKEDIN="https://www.linkedin.com/in/hboadar/"
SOCIAL_TWITTER="https://twitter.com/vezetaelea"
SOCIAL_GITHUB="https://github.com/vezetaelea/"
SOCIAL_FACEBOOK="#"

# ===========================================
# RBAC & INTELLIGENCE
# ===========================================
RBAC_MODE=granular
LEAD_SCORING_ENABLED=true
ROI_METRICS_ENABLED=true
INTERNAL_EVENTS_ENABLED=true

# ===========================================
# PASARELAS DE PAGO (MERCADOPAGO)
# ===========================================
MP_ACCESS_TOKEN=tu-access-token-aqui
MP_PUBLIC_KEY=tu-public-key-aqui
MP_CURRENCY_ID=ARS
MP_EXCHANGE_RATE=1050.00

# ===========================================
# INSTRUCCIONES BANCARIAS (TRANSFERENCIAS)
# ===========================================
BANK_NAME="Ecosistema Digital Bank"
BANK_ACCOUNT_NAME="VeZetaeLeA Services LLC"
BANK_ACCOUNT_NUMBER="1234-5678-9012"
BANK_CBU_ALIAS="vezetaelea.usd"

# ===========================================
# MODULO GAI (GENERATIVE AI)
# ===========================================
AI_PROVIDER="groq"
AI_MODEL="llama-3.1-8b-instant"
AI_API_KEY="tu-api-key"
