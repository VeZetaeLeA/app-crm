# ===========================================
# VEZETAELEA OS - CONFIGURACIÓN DE ENTORNO
# ===========================================

# ===========================================
# VARIABLE OBLIGATORIA: local | demo | production
# ===========================================
ENVIRONMENT=local

# ===========================================
# APLICACIÓN
# ===========================================
APP_NAME="VeZetaeLeA OS"
APP_URL=http://localhost/app-crm
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_CHARSET=UTF-8
APP_LOCALE=es
APP_KEY=generar_clave_32_caracteres

# ===========================================
# BASE DE DATOS
# ===========================================
DB_HOST=localhost
DB_DATABASE=vezetaelea
DB_USERNAME=root
DB_PASSWORD=

# ===========================================
# REDIS (INFRAESTRUCTURA)
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# SEGURIDAD Y JWT
# ===========================================
JWT_SECRET=super-secret-token-change-this
JWT_TTL=3600
REFRESH_TOKEN_TTL=2592000 # 30 días

SESSION_LIFETIME=14400
SESSION_HEARTBEAT=300
SESSION_WARNING=300

# ===========================================
# SECURITY HARDENING
# ===========================================
AUTH_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY=60
AUTH_BRUTE_FORCE_BLOCK=1800
AUTH_ACCOUNT_LOCK=900
AUTH_HASH_ALGO=argon2id
GLOBAL_RATE_LIMIT=100
GLOBAL_RATE_LIMIT_WINDOW=60

# ===========================================
# EMAIL (Configurar para demo/production)
# ===========================================
MAIL_ENABLED=false
MAIL_QUEUE=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=contacto@vezetaelea.com
MAIL_FROM_NAME="VeZetaeLeA OS"

# ===========================================
# TIPOGRAFÍA Y ESTÉTICA (UX / BRANDING)
# Cambiar estas variables ajusta fuentes en TODA la plataforma.
# ===========================================
FONT_URL="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600&family=Sora:wght@300;400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
FONT_HEADING="'Bricolage Grotesque', 'Sora', system-ui, sans-serif"
FONT_BODY="'Inter', system-ui, sans-serif"
FONT_MONO="'JetBrains Mono', 'Courier New', monospace"
TYPO_SCALE_RATIO=1.333

# ===========================================
# UI — DESIGN SYSTEM TOKENS (Color Palette)
# Modificar aquí propaga el cambio a TODA la UI sin tocar CSS.
# Estos valores son inyectados por PHP en cada layout como CSS custom properties.
# ===========================================
# Fondos (Dark Mode - Atmospheric Contrast)
UI_COLOR_BG_DARK="#030712"
UI_COLOR_SURFACE_DARK="#0F172A"
UI_COLOR_SURFACE_ELEVATED="#1E293B"
UI_COLOR_BORDER_DARK="rgba(255,255,255,0.06)"
# Fondos (Light Mode - Clear Concierge)
UI_COLOR_BG_LIGHT="#F8FAFC"
UI_COLOR_SURFACE_LIGHT="#FFFFFF"
UI_COLOR_BORDER_LIGHT="rgba(15, 23, 42, 0.08)"
# Acentos de Marca (Atmospheric Tech)
UI_PRIMARY_COLOR="#0033FF"
UI_SECONDARY_COLOR="#3D6BFF"
UI_GOLD_COLOR="#D4AF37"
# Colores Semánticos (CRM / Badges de estado)
UI_COLOR_SUCCESS="#10B981"
UI_COLOR_WARNING="#F59E0B"
UI_COLOR_DANGER="#EF4444"
UI_COLOR_INFO="#3B82F6"
# Border Radius (Balance humano/técnico)
UI_RADIUS_SM="6px"
UI_RADIUS_MD="12px"
UI_RADIUS_LG="20px"
UI_RADIUS_PILL="50rem"

# ===========================================
# PARÁMETROS DE NEGOCIO (SLA & BRANDING)
# ===========================================
COMPANY_NAME="VeZetaeLeA"
COMPANY_SLOGAN="Ingeniería de Datos de Vanguardia"
COMPANY_MAIL="contacto@vezetaelea.com"
COMPANY_PHONE="+54 9 11 7021 5822"
COMPANY_ADDRESS="Corrientes 5712, Villa Crespo, CP 1414, CABA, Argentina"
COMPANY_EST_YEAR="2017"

SLA_RESPONSE_TIME="24h"
CURRENCY_SYMBOL="$"
TAX_RATE=0.21
SHOW_ENTERPRISE_PROFILE=false
COMPANY_YEARS_EXP=10
COMPANY_PROJECTS_DELIVERED=45

# ===========================================
# SOCIAL MEDIA links
# ===========================================
SOCIAL_INSTAGRAM="https://www.instagram.com/vezetaelea/"
SOCIAL_LINKEDIN="https://www.linkedin.com/in/hboadar/"
SOCIAL_TWITTER="https://twitter.com/vezetaelea"
SOCIAL_GITHUB="https://github.com/vezetaelea/"
SOCIAL_FACEBOOK="#"

# ===========================================
# RBAC & INTELLIGENCE
# ===========================================
RBAC_MODE=granular
LEAD_SCORING_ENABLED=true
ROI_METRICS_ENABLED=true
INTERNAL_EVENTS_ENABLED=true

# ===========================================
# PASARELAS DE PAGO (MERCADOPAGO)
# ===========================================
MP_ACCESS_TOKEN=tu-access-token-aqui
MP_PUBLIC_KEY=tu-public-key-aqui
MP_CURRENCY_ID=ARS
MP_EXCHANGE_RATE=1050.00

# ===========================================
# INSTRUCCIONES BANCARIAS (TRANSFERENCIAS)
# ===========================================
BANK_NAME="Ecosistema Digital Bank"
BANK_ACCOUNT_NAME="VeZetaeLeA Services LLC"
BANK_ACCOUNT_NUMBER="1234-5678-9012"
BANK_CBU_ALIAS="vezetaelea.usd"

# ===========================================
# MODULO GAI (GENERATIVE AI)
# ===========================================
AI_PROVIDER="groq"
AI_MODEL="llama-3.1-8b-instant"
AI_API_KEY="tu-api-key"
